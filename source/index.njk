---
layout: base.njk
title: Home
description: Illustration inspired by retro tech and fuelled by the open-source movement
bodyColor: bg-highlight
---

{# HEADER #}
<div id="home-header" class="section medium-grid bg-highlight">
    <div class="section-column">
        <div class="header-featured-image bg-muted">
            {% image "source/assets/img/featured/novision-02.png", "Illustration of beaten down character", [720, 1400], "(min-width: 720px) 720px, 1400px", { eager: true } %}
            {# BADGE #}
            <div class="header-badge flex-center no-blend hide-small fade-in">
                {% image "source/assets/img/nogood_sign.png", "NoGood sign" %}
                <svg class="header-badge-text" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                    <defs>
                        <path id="circle-path" d="M 50,50 m -35,0 a 35,35 0 1,1 70,0 a 35,35 0 1,1 -70,0" />
                    </defs>
                    <text>
                        <textPath href="#circle-path" class="uppercase pixel-font">UP TO NOGOOD ⚡ UP TO NOGOOD ⚡
                        </textPath>
                    </text>
                </svg>
            </div>
        </div>
    </div>
    {# INTRO #}
    <div class="section-column sticky-two-rows">
        <div class="sticky-wrapper">
            <div class="sticky">
                <div class="header-introduction">
                    <h1 class="header">
                        I’m a freelance illustrator inspired by retro tech and fuelled by the open-source movement.
                    </h1>
                </div>
            </div>
        </div>

        {# CONTACT #}
        <div class="place-bottom">
            <div class="spacer-large"></div>
            <span
                class="tag pixel-font self-center {% if status.available %}tag-available{% else %}tag-unavailable{% endif %}">
                {% if status.available %}{{ status.availability_label }}{% else %}{{ status.unavailability_label }}{%
                endif %}
            </span>
            <div class="spacer-small"></div>
            <p>
                Get in touch: <a href="mailto:{{ settings.metadata.site_email }}">{{ settings.metadata.site_email
                    }}</a><br>
                Based in Amsterdam, The Netherlands — working worldwide.
            </p>
        </div>
    </div>
    {# STATUS #}
    <div class="section-column hide-small hide-medium sticky-two-rows">
        <div class="sticky-wrapper">
            <div class="sticky">
                {# NOW #}
                <div class="now">
                    <h5 class="uppercase pixel-font">Now</h5>
                    <p>
                        Shipped all <a href="/the-nogood-book/">The NoGood Book</a> pre-orders and just finished a
                        fairly large illustration project. Taking some time to step back and recharge.
                    </p>
                    <div class="spacer-small"></div>
                    <a href="/now/">Read more</a>
                </div>
                <div class="spacer-large line"></div>
                {# LATEST PRODUCT #}
                <div class="latest-product">
                    <h5 class="uppercase pixel-font">
                        <a href="/shop/">Shop</a>
                        > Latest addition
                    </h5>
                    <div class="spacer-small"></div>
                    {% for post in collections.product | reverse %}
                    {% if loop.index0 < 1 %} {# IMAGE #} <div class="shop-featured-image zoom bg-{{ post.data.site.background_color }} {% if
                                    post.data.site.override_blend_mode === true %}no-blend{% endif %}">
                        <a href="{{ post.url }} ">
                            {% image post.data.site.featured_image_url, post.data.title %}
                        </a>
                </div>
                <div class="spacer-small"></div>
                <div>
                    <a href="{{ post.url }}">{{ post.data.title }}</a>
                </div>
                {% endif %}
                {% endfor %}
            </div>
            <div class="spacer-large line"></div>
        </div>
    </div>
    {# RECENT ZAPS #}
    <div class="place-bottom">
        <h5 class="uppercase pixel-font">Recent supporters</h5>
        <div class="spacer-small"></div>
        <div id="home-zap-feed" class="zap-feed animate-in"></div>
    </div>
</div>
</div>
{# PORTFOLIO #}
<div id="portfolio" class="section bg-dark text-light">
    <div class="section-column pixel-font uppercase">
        <h3>featured work / <a href="/work/">all work</a></h3>
        <div class="spacer-large"></div>
    </div>
    {# CAROUSEL #}
    <div class="section-column portfolio-carousel">
        <div class="portfolio-carousel-track">
            {% for item in featuredimg.items %}
            <div class="inner-column portfolio-item">
                <div class="portfolio-featured-img bg-light">
                    {% image item.src, item.alt %}
                </div>
            </div>
            {% endfor %}
            {% for item in featuredimg.items %}
            <div class="inner-column portfolio-item" aria-hidden="true">
                <div class="portfolio-featured-img">
                    {% image item.src, item.alt %}
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</div>
{# ABOUT #}
<div id="background" class="section bg-muted large-grid">
    <div class="section-column sticky-two-rows">
        <div class="sticky-wrapper">
            <div class="sticky">
                <h1>
                    My illustrations, through the rickety hardware and clunky modded devices they feature, are informed
                    by notions of ownership and control.
                </h1>
            </div>
        </div>
        <div class="spacer-small hide-medium hide-large"></div>
        <div class="flex-row gap-large hide-medium hide-large">
            <a href="/work/">See work</a>
            <a href="/about/">Learn more</a>
        </div>
        <div class="spacer hide-small"></div>
        <div class="place-bottom padding-right-small hide-small">
            <p class="text-large">
                I established NoGood in 2021.
                More than a pseudonym, I found that NoGood provided a space to experiment.
                Since then, my commissioned projects and my personal work started to blend,
                establishing a throughline that spans multiple years.
            </p>
            <div class="spacer-small"></div>
            <div class="flex-row flex-align-center gap-large">
                <span
                    class="tag pixel-font self-center {% if status.available %}tag-available{% else %}tag-unavailable{% endif %}">
                    {% if status.available %}{{ status.availability_label }}{% else %}{{ status.unavailability_label
                    }}{% endif %}
                </span>
                <span class="text-small">Get in touch: <a href="mailto:{{ settings.metadata.site_email }}">{{
                        settings.metadata.site_email }}</a></span>
            </div>
        </div>
    </div>
    {# SELF PORTRAIT #}
    <div class="section-column">
        <div class="image-padding-extralarge bg-dark no-blend">
            {% image "source/assets/img/NoGood_Selfpotrait_Dark.png", "NoGood self portrait" %}
        </div>
    </div>

</div>
{# RADIO #}
<div class="section relative hide-small bg-highlight">
    {# VIDEO #}
    <div class="section-column no-blend">
        <div class="video-fill">
            <video id="home-stream-video" muted playsinline></video>
        </div>
    </div>
</div>
<script type="module">
    import Hls from '/assets/js/vendor/hls.js';
    const video = document.getElementById('home-stream-video');
    const HLS_URL = 'https://api-core.zap.stream/537a365c-f1ec-44ac-af10-22d14a7319fb/hls/live.m3u8';
    const FALLBACK = '/assets/img/radio-bg.mp4';
    function useFallback() {
        video.src = FALLBACK;
        video.loop = true;
        video.play().catch(() => {});
    }
    function initStream() {
        if (Hls.isSupported()) {
            const hls = new Hls({ enableWorker: true, startLevel: 0 });
            hls.loadSource(HLS_URL);
            hls.attachMedia(video);
            hls.on(Hls.Events.MANIFEST_PARSED, () => {
                video.play().catch(() => {});
            });
            hls.on(Hls.Events.ERROR, (_e, data) => {
                if (data.fatal) { hls.destroy(); useFallback(); }
            });
        } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
            video.src = HLS_URL;
            video.play().catch(() => {});
            video.addEventListener('error', useFallback);
        } else {
            useFallback();
        }
    }
    new IntersectionObserver((entries, obs) => {
        if (entries[0].isIntersecting) {
            obs.disconnect();
            initStream();
        }
    }, { threshold: 0.1 }).observe(video);
</script>
{# SHOP MARQUEE #}
