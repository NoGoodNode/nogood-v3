---
layout: overlay
title: NoGood Radio — Zap Bar
permalink: /overlay/zap-bar/
eleventyExcludeFromCollections: true
---

<style>
  * {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
  }

  @font-face {
    font-family: 'Offbit-Bold';
    src: url('/assets/fonts/OffBit-Bold.woff2') format('woff2'),
         url('/assets/fonts/OffBit-Bold.woff') format('woff');
    font-weight: 700;
    font-style: normal;
  }

  @font-face {
    font-family: 'UntitledSans-Regular';
    src: url('/assets/fonts/untitled-sans-regular.woff2') format('woff2');
    font-weight: 400;
    font-style: normal;
  }

  @font-face {
    font-family: 'PPSupplyMono';
    src: url('/assets/fonts/PPSupplyMono-Regular.woff2') format('woff2'),
         url('/assets/fonts/PPSupplyMono-Regular.woff') format('woff');
    font-weight: 400;
    font-style: normal;
  }

  @font-face {
    font-family: 'PPSupplyMono';
    src: url('/assets/fonts/PPSupplyMono-Medium.woff2') format('woff2'),
         url('/assets/fonts/PPSupplyMono-Medium.woff') format('woff');
    font-weight: 400;
    font-style: normal;
  }

  @font-face {
    font-family: 'PPSupplyMono';
    src: url('/assets/fonts/PPSupplyMono-Bold.woff2') format('woff2'),
         url('/assets/fonts/PPSupplyMono-Bold.woff') format('woff');
    font-weight: 700;
    font-style: normal;
  }

#zap-bar, #name-bar {
    position: absolute;
    bottom: 15px;
    height: 30px;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 0 10px;
    background: rgba(28, 28, 28, 0.75);
    transition: opacity 0.4s ease;
  }

  #zap-bar {
    right: 15px;
    width: 220px;
    overflow: hidden;
    padding: 0;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.4s ease, transform 0.4s ease, background-color 0.4s ease;
  }

  #name-bar {
    left: 15px;
    width: 30%;
    overflow: hidden;
    background: rgb(28, 28, 28);
  }

  #mempool-wrap {
    position: absolute;
    top: 15px;
    left: 15px;
    display: flex;
    flex-direction: row;
    align-items: stretch;
  }

  #mempool-bar {
    background: rgba(28, 28, 28, 0.75);
    border-left: 1px solid rgb(248, 194, 40);
    width: fit-content;
    display: grid;
    grid-template-columns: auto auto;
    column-gap: 30px;
    row-gap: 1px;
    padding: 8px 10px 6px 10px;
    align-items: center;
  }

  #block-bar {
    display: none;
    position: absolute;
    left: 100%;
    top: 0;
    bottom: 0;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    overflow: hidden;
    padding: 8px 10px 6px 10px;
    background: rgb(28, 28, 28);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  #block-bar.is-visible {
    opacity: 1;
  }

  #block-gif {
    width: 100%;
    height: 50px;
    object-fit: contain;
    overflow: hidden;
  }

  #block-text {
    font-family: 'PPSupplyMono', monospace;
    font-size: 0.9rem;
    color: rgb(248, 194, 40);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
    text-align: center;
  }

  .mempool-row {
    display: contents;
  }

  .mempool-cell {
    font-family: 'PPSupplyMono', monospace;
    font-weight: 400;
    font-size: 0.9rem;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  .mempool-label {
    color: rgb(251, 250, 243);
    text-transform: uppercase;
  }

  .mempool-value {
    text-align: right;
    justify-self: end;
    color: rgb(251, 250, 243);
  }

  #name-scroll {
    flex: 1;
    overflow: hidden;
    min-width: 0;
    transform: translateY(2px);
  }

  #name-track {
    display: flex;
    gap: 20px;
    white-space: nowrap;
    will-change: transform;
  }

  @keyframes scrollNames {
    from { transform: translateX(0); }
    to   { transform: translateX(var(--scroll-width)); }
  }

  #name-bar-label {
    font-family: 'PPSupplyMono', monospace;
    font-weight: 400;
    font-size: 1rem;
    color: rgb(248, 194, 40);
    letter-spacing: 0.04em;
    line-height: 1;
    white-space: nowrap;
    flex-shrink: 0;
    padding-right: 5px;
    transform: translateY(2px);
  }

  .name-item {
    font-family: 'PPSupplyMono', monospace;
    font-weight: 400;
    font-size: 1rem;
    color: rgb(251, 250, 243);
    letter-spacing: 0.04em;
    line-height: 1;
    flex-shrink: 0;
  }

  @keyframes zapTickerScroll {
    from { transform: translateX(0); }
    to   { transform: translateX(var(--scroll-width)); }
  }

  .zap-text-base {
    font-family: 'PPSupplyMono', monospace;
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    line-height: 1;
    display: inline-block;
    transform: translateY(1px);
    white-space: nowrap;
    text-transform: uppercase;
  }

  .zap-text-announce { color: rgb(28, 28, 28); }
  .zap-text-message  { color: rgb(251, 250, 243); }

  .zap-text-amount,
  .zap-text-thanks {
    font-family: 'PPSupplyMono', monospace;
    font-size: 1rem;
    font-weight: 400;
    color: rgb(248, 194, 40);
    letter-spacing: 0.08em;
    line-height: 1;
    display: block;
    width: 100%;
    text-align: center;
    text-transform: uppercase;
    transform: translateY(1px);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .zap-text-thanks {
    color: rgb(251, 250, 243);
    letter-spacing: 0.04em;
  }

#chat-box {
    position: absolute;
    left: 15px;
    bottom: 65px;
    width: 340px;
    max-height: 520px;
    overflow-y: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background: rgba(28, 28, 28, 0.75);
    border-left: 1px solid rgb(248, 194, 40);
    padding: 20px;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  #chat-box::-webkit-scrollbar { display: none; }

  .ov-msg {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-family: 'UntitledSans-Regular', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    color: rgb(251, 250, 243);
    letter-spacing: 0.02em;
    line-height: 1.5;
  }

  .ov-msg + .ov-msg { margin-top: 6px; }

  .ov-emoji {
    display: inline-block;
    height: 1.25em;
    width: auto;
    vertical-align: middle;
    margin: 0 0.1em;
  }

  .ov-msg--zap {
    outline: 1px solid rgb(160, 80, 240);
    border-radius: 4px;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
    padding: 10px 12px;
  }

  .ov-msg--zap .ov-msg-name { color: rgb(160, 80, 240); }

  .ov-msg--zap-small {
    background: rgba(160, 80, 240, 0.15);
    outline-color: rgb(160, 80, 240);
  }
  .ov-msg--zap-small .ov-msg-name { color: rgb(160, 80, 240); }

  .ov-msg--zap-big { outline-color: #6faca0; }
  .ov-msg--zap-big .ov-msg-name { color: #6faca0; }

  @keyframes megaZapGlow {
    0%, 100% { box-shadow: 0 0 6px rgba(248, 194, 40, 0.35); }
    50%       { box-shadow: 0 0 18px rgba(248, 194, 40, 0.75), 0 0 32px rgba(248, 194, 40, 0.2); }
  }

  .ov-msg--zap-mega {
    background: rgba(248, 194, 40, 0.2);
    outline-color: rgb(248, 194, 40);
    animation: megaZapGlow 2.5s ease-in-out infinite;
  }

  .ov-msg--zap-mega .ov-msg-name {
    color: rgb(248, 194, 40);
  }

  .ov-msg-zap-header {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  @keyframes letterBounce {
    0%,  18%, 100% { transform: translateY(0); }
    8%              { transform: translateY(-2px); }
    14%             { transform: translateY(1px); }
  }

  .ov-msg-zap-amount span {
    display: inline-block;
    animation: letterBounce 2.5s ease infinite;
  }

  .ov-msg-link { opacity: 0.6; }
  .ov-msg-mention { color: rgb(160, 80, 240); }

  .ov-msg-content {
    font-family: 'UntitledSans-Regular', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    color: rgb(251, 250, 243);
    letter-spacing: 0.02em;
    line-height: 1.5;
    word-break: break-word;
    overflow-wrap: break-word;
  }

  .ov-msg-avatar {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .ov-msg-body {
    flex: 1;
    min-width: 0;
    word-break: break-word;
    overflow-wrap: break-word;
    overflow: hidden;
  }

  .ov-msg-name {
    font-family: 'PPSupplyMono', monospace;
    color: rgb(161, 154, 137);
    margin-right: 4px;
  }

  .ov-msg--zap .ov-msg-name {
    max-width: 160px;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }

  .ov-msg-zap-amount {
    font-family: 'PPSupplyMono', monospace;
    display: inline-flex;
  }

  .ov-msg--raid {
    background: rgba(160, 80, 240, 0.35);
    border-radius: 4px;
    padding: 10px 12px;
    font-family: 'PPSupplyMono', monospace;
    font-size: 1rem;
    color: rgb(251, 250, 243);
    letter-spacing: 0.04em;
  }

  .ov-msg--raid span { display: inline-block; transform: translateY(1px); }

  #now-playing-bar {
    position: absolute;
    top: 20px;
    left: 42%;
    width: 520px;
    height: 36px;
    overflow: hidden;
    background: rgb(248, 194, 40);
    display: flex;
    align-items: center;
    padding: 0 10px 0 80px;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  #viewers-bar {
    position: absolute;
    top: 20px;
    left: calc(42% + 540px);
    height: 36px;
    background: rgba(28, 28, 28, 0.75);
    border-left: 1px solid rgb(248, 194, 40);
    display: flex;
    align-items: center;
    padding: 0 10px;
    opacity: 0;
    transition: opacity 0.4s ease;
    white-space: nowrap;
    font-family: 'PPSupplyMono', monospace;
    font-size: 0.9rem;
    font-weight: 400;
    color: rgb(251, 250, 243);
    letter-spacing: 0.06em;
    line-height: 1;
    text-transform: uppercase;
  }

  #viewers-bar span { transform: translateY(1px); display: inline-block; }

  #follow-feed {
    position: absolute;
    bottom: 20%;
    right: 0;
    width: 300px;
    display: flex;
    flex-direction: column-reverse;
    align-items: flex-end;
    gap: 5px;
    pointer-events: none;
    border-right: 3px solid rgb(248, 194, 40);
    padding-right: 15px;
  }

  .follow-notif {
    font-family: 'PPSupplyMono', monospace;
    font-weight: 400;
    font-size: 0.9rem;
    color: rgb(251, 250, 243);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    text-align: right;
    opacity: 0;
  }

  .follow-notif.is-in  { opacity: 1; }
  .follow-notif.is-out { opacity: 0; }

  #node-bar {
    position: absolute;
    bottom: 605px;
    left: 15px;
    opacity: 0;
    transition: opacity 0.4s ease;
    background: transparent;
    display: flex;
    align-items: center;
    white-space: nowrap;
    font-family: 'PPSupplyMono', monospace;
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.06em;
    line-height: 1;
    text-transform: uppercase;
    padding: 8px 12px;
    border-radius: 999px;
    border: 1px solid;
  }

  #node-bar span:not(.node-dot) { transform: translateY(1px); display: inline-block; }
  #node-bar.node-online  { color: rgb(216, 255, 124); border-color: rgb(216, 255, 124); background: rgba(216, 255, 124, 0.2); }
  #node-bar.node-offline { color: #e57373;           border-color: #e57373;           background: rgba(229, 115, 115, 0.2); }

  @keyframes nodeBlink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.2; }
  }

  .node-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    margin-left: 7px;
    animation: nodeBlink 3s ease-in-out infinite;
    flex-shrink: 0;
    vertical-align: middle;
  }

  .node-online  .node-dot { background: rgb(216, 255, 124); }
  .node-offline .node-dot { background: #e57373; }

  #np-scroll {
    flex: 1;
    overflow: hidden;
    min-width: 0;
    transform: translateY(1px);
  }

  @keyframes scrollNowPlaying {
    from { transform: translateX(0); }
    to   { transform: translateX(var(--np-scroll-width)); }
  }

  #np-track {
    display: flex;
    white-space: nowrap;
    will-change: transform;
  }

  .np-item {
    font-family: 'PPSupplyMono', monospace;
    font-size: 1em;
    font-weight: 400;
    color: rgb(28, 28, 28);
    letter-spacing: 0.04em;
    line-height: 1.3;
    flex-shrink: 0;
  }

  .np-sep {
    font-family: 'PPSupplyMono', monospace;
    font-size: 1em;
    font-weight: 400;
    color: rgb(28, 28, 28);
    letter-spacing: 0;
    line-height: 1;
    transform: translateY(1px);
    flex-shrink: 0;
    padding: 0 14px;
  }

  #zap-floats {
    position: absolute;
    right: 0;
    top: 0;
    width: 500px;
    height: 1080px;
    pointer-events: none;
    overflow: hidden;
  }

  @keyframes floatUp {
    0%   { transform: translateY(0)      translateX(0);                          opacity: 0; }
    8%   {                                                                        opacity: 1; }
    50%  { transform: translateY(-600px) translateX(calc(var(--drift, 80px) * 0.5)); }
    85%  {                                                                        opacity: 1; }
    100% { transform: translateY(-1200px) translateX(var(--drift, 80px));         opacity: 0; }
  }

  .zap-float {
    position: absolute;
    border-radius: 50%;
    object-fit: cover;
    font-size: 60%;
    animation: floatUp linear forwards;
  }

  #overlay-badge {
    position: absolute;
    top: 15px;
    right: 15px;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: rgb(28, 28, 28);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s ease, transform 0.8s ease;
    z-index: 100;
  }

  #badge-sign {
    width: 52px;
    height: 52px;
    object-fit: contain;
}

  @keyframes badgeSpin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  #badge-text {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    font-size: 12.6px;
    fill: rgb(251, 250, 243);
    font-family: 'Offbit-Bold', Arial, sans-serif;
    letter-spacing: 0.05rem;
    text-transform: uppercase;
    animation: badgeSpin 12s linear infinite;
  }
  #book-sale-bar {
    position: absolute;
    bottom: 15px;
    left: 42%;
    width: 160px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 14px;
    background: rgb(216, 255, 124);
    padding: 15px 15px 10px 15px;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  #book-sale-bar picture { display: block; width: 100%; opacity: 0; }
  #book-sale-bar img { width: 100%; height: auto; display: block; }

  @keyframes bookItemIn {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .book-item-in  { animation: bookItemIn 0.4s ease both; }
  .book-item-out { animation: bookItemIn 0.3s ease reverse both; }

  #book-sale-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  #book-sale-label {
    font-family: 'PPSupplyMono', monospace;
    font-size: 1rem;
    font-weight: 400;
    color: rgb(28, 28, 28);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1;
    white-space: nowrap;
    opacity: 0;
  }

  #book-sale-counter {
    font-family: 'PPSupplyMono', monospace;
    font-size: 0.85rem;
    font-weight: 400;
    color: rgb(28, 28, 28);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1;
    white-space: nowrap;
    opacity: 0;
  }
</style>

<div id="overlay-badge">
  <img id="badge-sign" src="/assets/img/nogood_sign.png" alt="NoGood sign">
  <svg id="badge-text" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <path id="badge-circle-path" d="M 50,50 m -35,0 a 35,35 0 1,1 70,0 a 35,35 0 1,1 -70,0"/>
    </defs>
    <text><textPath href="#badge-circle-path">UP TO NOGOOD ⚡ UP TO NOGOOD ⚡</textPath></text>
  </svg>
</div>
<div id="now-playing-bar"><div id="np-scroll"><div id="np-track"></div></div></div>
<div id="viewers-bar"></div>
<div id="follow-feed"></div>
<div id="node-bar"></div>
<div id="mempool-wrap">
  <div id="mempool-bar"></div>
  <div id="block-bar">
    <img src="/overlay/zap-bar/NG_Block_Animation.gif" alt="" aria-hidden="true" id="block-gif">
    <span id="block-text"></span>
  </div>
</div>
<div id="chat-box"></div>
<div id="zap-bar"></div>
<div id="zap-floats"></div>
<div id="name-bar">
  <span id="name-bar-label">GEYSER BACKERS</span>
  <div id="name-scroll"><div id="name-track"></div></div>
</div>
<div id="book-sale-bar">
  {% image "source/assets/img/shop/NoGoodBook_Collectors.png", "The NoGood Book", [320], "160px", { eager: true } %}
  <div id="book-sale-info">
    <span id="book-sale-label">New Order</span>
    <span id="book-sale-counter">— / {{ booksales.total_print_run }}</span>
  </div>
</div>

<script>
  // ----------------
  // ZAP BAR
  // ----------------
  const MAX_ZAPS = 5;
  const bar = document.getElementById('zap-bar');
  let resolveNamesReady, resolveMempoolReady, resolveChatReady;
  const namesReady   = new Promise(r => { resolveNamesReady   = r; });
  const mempoolReady = new Promise(r => { resolveMempoolReady = r; });
  const chatReady    = new Promise(r => { resolveChatReady    = r; window.__resolveChatReady = r; });

  namesReady.then(()   => { document.getElementById('name-bar').style.opacity    = '1'; });
  mempoolReady.then(() => { document.getElementById('mempool-bar').style.opacity = '1'; });
  chatReady.then(()    => { document.getElementById('chat-box').style.opacity    = '1'; });

  const zapQueue = [];
  let zapShowing = false;
  const ZAP_GAP = 30;

  function phaseScroll(text, cssClass) {
    return new Promise(resolve => {
      bar.innerHTML = '';
      const track = document.createElement('div');
      track.style.cssText = 'display:flex;white-space:nowrap;will-change:transform;opacity:0;transition:opacity 0.4s ease';
      [text, text, text, text, text, text].forEach(t => {
        const s = document.createElement('span');
        s.className = cssClass;
        s.textContent = t;
        s.style.marginRight = ZAP_GAP + 'px';
        track.appendChild(s);
      });
      bar.appendChild(track);
      requestAnimationFrame(() => {
        const hw = track.scrollWidth / 2;
        track.style.setProperty('--scroll-width', `-${hw}px`);
        track.style.animation = `zapTickerScroll ${Math.max(hw / 35, 2).toFixed(2)}s linear infinite`;
        requestAnimationFrame(() => {
          track.style.opacity = '1';
          setTimeout(() => { track.style.opacity = '0'; setTimeout(resolve, 400); }, 4000);
        });
      });
    });
  }

  function phaseStatic(text, cssClass) {
    return new Promise(resolve => {
      bar.innerHTML = '';
      const el = document.createElement('span');
      el.className = cssClass;
      el.textContent = text;
      el.style.cssText = 'opacity:0;transition:opacity 0.4s ease';
      bar.appendChild(el);
      requestAnimationFrame(() => requestAnimationFrame(() => {
        el.style.opacity = '1';
        setTimeout(() => { el.style.opacity = '0'; setTimeout(resolve, 400); }, 4000);
      }));
    });
  }

  function showNextZap() {
    if (zapQueue.length === 0) { zapShowing = false; return; }
    zapShowing = true;
    const zap = zapQueue.shift();

    bar.innerHTML = '';
    launchFloats(zap);

    setTimeout(() => {
      bar.style.backgroundColor = 'rgb(248, 194, 40)';
      requestAnimationFrame(() => requestAnimationFrame(() => {
        bar.style.opacity = '1';
        bar.style.transform = 'translateY(0)';
      }));

      let chain = phaseScroll('ZAP RECEIVED', 'zap-text-base zap-text-announce')
        .then(() => new Promise(r => {
          bar.style.backgroundColor = 'rgb(28, 28, 28)';
          setTimeout(r, 400);
        }))
        .then(() => phaseStatic(`⚡ ${zap.sats.toLocaleString()} sats`, 'zap-text-amount'));
      if (zap.message) chain = chain.then(() => phaseScroll(zap.message, 'zap-text-base zap-text-message'));
      chain
        .then(() => new Promise(resolve => {
          bar.innerHTML = '';
          const el = document.createElement('span');
          el.className = 'zap-text-thanks';
          el.textContent = zap.name || 'anon';
          el.style.cssText = 'opacity:0;transition:opacity 0.4s ease';
          bar.appendChild(el);
          requestAnimationFrame(() => requestAnimationFrame(() => {
            el.style.opacity = '1';
            setTimeout(resolve, 4000);
          }));
        }))
        .then(() => setTimeout(() => {
          bar.style.opacity = '0';
          bar.style.transform = 'translateY(8px)';
          setTimeout(showNextZap, 400);
        }, 1000));
    }, 3000);
  }

  function getFloatCount(sats) {
    if (sats >= 10000) return 120;
    if (sats >= 5000)  return 80;
    if (sats >= 1000)  return 50;
    if (sats >= 500)   return 30;
    if (sats >= 100)   return 18;
    return 10;
  }

  function launchFloats(zap) {
    const container = document.getElementById('zap-floats');
    const count = getFloatCount(zap.sats);
    const spread = Math.min(count * 200, 4000);

    for (let i = 0; i < count; i++) {
      setTimeout(() => {
        let el;
        if (zap.avatar) {
          el = document.createElement('img');
          el.src = zap.avatar;
          el.onerror = function() {
            const fallback = document.createElement('div');
            fallback.textContent = '⚡';
            fallback.style.cssText = this.style.cssText + ';display:flex;align-items:center;justify-content:center;border-radius:0;background:none;';
            this.replaceWith(fallback);
          };
        } else {
          el = document.createElement('div');
          el.textContent = '⚡';
          el.style.cssText = 'display:flex;align-items:center;justify-content:center;border-radius:0;';
        }
        el.className = 'zap-float';

        const size  = 20 + Math.random() * 16;
        const x     = Math.random() * (500 - size);
        const dur   = 6 + Math.random() * 4;
        const drift = (80 + Math.random() * 80) + 'px';

        el.style.width             = size + 'px';
        el.style.height            = size + 'px';
        el.style.left              = x + 'px';
        el.style.top               = '1080px';
        el.style.animationDuration = dur + 's';
        el.style.setProperty('--drift', drift);

        container.appendChild(el);
        setTimeout(() => el.remove(), dur * 1000 + 200);
      }, (i / count) * spread);
    }
  }

  function addZap(zap) {
    zapQueue.push(zap);
    if (!zapShowing) showNextZap();
  }

  // ----------------
  // NAMES BAR
  // ----------------
  (async function() {
    const track = document.getElementById('name-track');
    const res = await fetch('/overlay/names.txt').catch(() => null);
    if (!res || !res.ok) { resolveNamesReady(); return; }
    const names = (await res.text()).split('\n').map(n => n.trim()).filter(Boolean);
    if (!names.length) { resolveNamesReady(); return; }

    const doubled = [...names, ...names];
    doubled.forEach(name => {
      const span = document.createElement('span');
      span.className = 'name-item';
      span.textContent = name;
      track.appendChild(span);
    });

    requestAnimationFrame(() => {
      const singleWidth = track.scrollWidth / 2;
      const duration = singleWidth / 12;
      track.style.setProperty('--scroll-width', `-${singleWidth}px`);
      track.style.animation = `scrollNames ${duration}s linear infinite`;
      resolveNamesReady();
    });
  })();

  // ----------------
  // MEMPOOL BAR
  // ----------------
  const mempoolBar = document.getElementById('mempool-bar');
  const MEMPOOL_FIELDS = [
    { label: 'BLOCK',      key: 'block' },
    { label: 'MEMPOOL',    key: 'count' },
    { label: 'FEE',        key: 'halfHourFee', suffix: ' sat/vB' },
    { label: 'DIFFICULTY', key: 'difficultyChange', suffix: '%' },
  ];

  function renderMempoolData(data) {
    mempoolBar.innerHTML = '';
    MEMPOOL_FIELDS.forEach(({ label, key, suffix = '' }) => {
      const val = data[key];
      if (val == null) return;
      const row = document.createElement('div');
      row.className = 'mempool-row';
      const l = document.createElement('span');
      l.className = 'mempool-cell mempool-label';
      l.textContent = label;
      const v = document.createElement('span');
      v.className = 'mempool-cell mempool-value';
      v.textContent = (typeof val === 'number' ? val.toLocaleString() : val) + suffix;
      row.appendChild(l);
      row.appendChild(v);
      mempoolBar.appendChild(row);
    });
    resolveMempoolReady();
  }

  async function fetchMempool() {
    try {
      const [block, mempool, fees, difficulty] = await Promise.all([
        fetch('https://mempool.space/api/blocks/tip/height').then(r => r.text()),
        fetch('https://mempool.space/api/mempool').then(r => r.json()),
        fetch('https://mempool.space/api/v1/fees/recommended').then(r => r.json()),
        fetch('https://mempool.space/api/v1/difficulty-adjustment').then(r => r.json()),
      ]);
      renderMempool({
        block: parseInt(block),
        count: mempool.count,
        halfHourFee: fees.halfHourFee,
        difficultyChange: (difficulty.difficultyChange > 0 ? '+' : '') + difficulty.difficultyChange.toFixed(2),
      });
    } catch { resolveMempoolReady(); }
  }

  // ----------------
  // BLOCK BAR
  // ----------------
  let lastBlockHeight = null;
  let blockBarTimeout = null;
  const blockBar  = document.getElementById('block-bar');
  const blockText = document.getElementById('block-text');
  const BLOCK_TEXTS = ['NEW BLOCK', null]; // null = block number

  function showBlockBar(height) {
    if (blockBarTimeout) clearTimeout(blockBarTimeout);

    // Lock width to widest text variant (position:absolute — no layout side effects)
    blockBar.style.visibility = 'hidden';
    blockBar.style.display = 'flex';
    blockBar.style.width = 'auto';
    const allTexts = BLOCK_TEXTS.map(t => t === null ? height.toLocaleString() : t);
    let maxWidth = 0;
    allTexts.forEach(t => {
      blockText.textContent = t;
      maxWidth = Math.max(maxWidth, blockBar.getBoundingClientRect().width);
    });
    blockBar.style.width = maxWidth + 'px';
    blockBar.style.visibility = '';
    requestAnimationFrame(() => blockBar.classList.add('is-visible'));

    let phase = 0;
    function cycleText() {
      const label = BLOCK_TEXTS[phase % BLOCK_TEXTS.length];
      blockText.textContent = label === null ? height.toLocaleString() : label;
      phase++;
    }
    cycleText();
    const cycleInterval = setInterval(cycleText, 8000);

    blockBarTimeout = setTimeout(() => {
      clearInterval(cycleInterval);
      blockBar.classList.remove('is-visible');
      setTimeout(() => { blockBar.style.display = 'none'; }, 400);
    }, 30000);
  }

  function renderMempool(data) {
    renderMempoolData(data);
    if (lastBlockHeight !== null && data.block > lastBlockHeight) {
      showBlockBar(data.block);
