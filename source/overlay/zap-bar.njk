  fetchMempool();
  setInterval(fetchMempool, 60000);


  // ----------------
  // NOW PLAYING
  // ----------------
  const npBar   = document.getElementById('now-playing-bar');
  const npTrack = document.getElementById('np-track');
  let npCurrentText = '';

  function setNowPlayingText(text) {
    if (text === npCurrentText) return;
    npCurrentText = text;

    const populate = () => {
      npTrack.style.animation = 'none';
      npTrack.innerHTML = '';
      Array(10).fill(text).forEach(t => {
        const span = document.createElement('span');
        span.className = 'np-item';
        span.textContent = t;
        npTrack.appendChild(span);
        const sep = document.createElement('span');
        sep.className = 'np-sep';
        sep.textContent = '//';
        npTrack.appendChild(sep);
      });
      requestAnimationFrame(() => {
        const singleWidth = npTrack.scrollWidth / 10;
        const duration = singleWidth / 12;
        npTrack.style.setProperty('--np-scroll-width', `-${singleWidth}px`);
        npTrack.style.animation = `scrollNowPlaying ${duration}s linear infinite`;
        npTrack.style.opacity = '1';
        npBar.style.opacity = '1';
      });
    };

    if (npBar.style.opacity === '1') {
      npTrack.style.transition = 'opacity 0.6s ease';
      npTrack.style.opacity = '0';
      setTimeout(populate, 600);
    } else {
      npTrack.style.opacity = '1';
      populate();
    }
  }

  async function fetchNowPlaying() {
    try {
      const resp = await fetch('https://lastfm-api.hello-5b9.workers.dev/', { cache: 'no-store' });
      if (!resp.ok) { setNowPlayingText('NOGOOD RADIO'); return; }
      const tracks = await resp.json();
      const current = tracks.find(t => !t.playedAt);
      if (!current) { setNowPlayingText('NOGOOD RADIO'); return; }

      setNowPlayingText(`${current.artist} — ${current.name}`);
    } catch { setNowPlayingText('NOGOOD RADIO'); }
  }

  fetchNowPlaying();
  setInterval(fetchNowPlaying, 10000);

  // ----------------
  // BADGE
  // ----------------
  const badge = document.getElementById('overlay-badge');
  const BADGE_WAIT = 8 * 60 * 1000;
  const BADGE_SHOW = 20 * 1000;

  function badgeCycle() {
    badge.style.opacity = '1';
    badge.style.transform = 'translateY(0)';
    setTimeout(() => {
      badge.style.opacity = '0';
      badge.style.transform = 'translateY(20px)';
      setTimeout(badgeCycle, BADGE_WAIT);
    }, BADGE_SHOW);
  }

  setTimeout(badgeCycle, BADGE_WAIT);

  // ----------------
  // NODE STATUS
  // ----------------
  const nodeBar = document.getElementById('node-bar');
  let nodeOfflineCount = 0;
  let nodeInitialized = false;
  const NODE_OFFLINE_THRESHOLD = 10; // 10 × 30s = 5 minutes

  function setNodeOnline() {
    nodeOfflineCount = 0;
    nodeBar.className = 'node-online';
    nodeBar.innerHTML = '<span>NOGOODNODE ONLINE</span><span class="node-dot"></span>';
    if (!nodeInitialized) { nodeInitialized = true; nodeBar.style.opacity = '1'; }
  }

  function setNodeOffline(force = false) {
    nodeOfflineCount++;
    if (force || nodeOfflineCount >= NODE_OFFLINE_THRESHOLD) {
      nodeBar.className = 'node-offline';
      nodeBar.innerHTML = '<span>NOGOODNODE OFFLINE</span><span class="node-dot"></span>';
      if (!nodeInitialized) { nodeInitialized = true; nodeBar.style.opacity = '1'; }
    }
  }

  async function checkNode() {
    try {
      const res = await fetch('https://btcpay.hello-5b9.workers.dev/health', {
        cache: 'no-store',
        signal: AbortSignal.timeout(5000)
      });
      const data = await res.json();
      res.ok && data.synchronized === true ? setNodeOnline() : setNodeOffline(!nodeInitialized);
    } catch {
      setNodeOffline(!nodeInitialized);
    }
  }

  checkNode();
  setInterval(checkNode, 30000);

  // ----------------
  // BOOK SALES
  // ----------------
  const GEYSER_SALES  = {{ booksales.geyser_sales }};
  const WP_SALES      = {{ booksales.wordpress_sales }};
  const PRINT_RUN     = {{ booksales.total_print_run }};
  const bookBar         = document.getElementById('book-sale-bar');
  const bookSaleCounter = document.getElementById('book-sale-counter');
  let lastBookOrderDate = null;
  let bookBarActive = false;
  const bookBarQueue = [];

  function displayBookBar(sold) {
    bookBarActive = true;
    const bookPicture = bookBar.querySelector('picture');
    const bookLabel   = document.getElementById('book-sale-label');
    if (sold !== null) {
      bookSaleCounter.textContent = sold + ' / ' + PRINT_RUN + ' sold';
      bookSaleCounter.style.display = '';
    } else {
      bookSaleCounter.style.display = 'none';
    }
    [bookPicture, bookLabel, bookSaleCounter].forEach((el, i) => {
      el.classList.remove('book-item-in');
      void el.offsetWidth;
      el.style.animationDelay = (i * 0.15) + 's';
      el.classList.add('book-item-in');
    });
    bookBar.style.opacity = '1';
    setTimeout(() => {
      [bookSaleCounter, bookLabel, bookPicture].forEach((el, i) => {
        el.classList.remove('book-item-in');
        void el.offsetWidth;
        el.style.animationDelay = (i * 0.15) + 's';
        el.classList.add('book-item-out');
      });
      setTimeout(() => {
        bookBar.style.opacity = '0';
        [bookPicture, bookLabel, bookSaleCounter].forEach(el => {
          el.classList.remove('book-item-out');
          el.style.animationDelay = '';
          el.style.display = '';
        });
        bookBarActive = false;
        if (bookBarQueue.length > 0) displayBookBar(bookBarQueue.shift());
      }, 3 * 150 + 300);
    }, 60000);
  }

  function showBookSale(sold) {
    if (bookBarActive) { bookBarQueue.push(sold); } else { displayBookBar(sold); }
  }

  async function waitForUpdatedCount(knownSold) {
    for (let i = 0; i < 4; i++) {
      await new Promise(r => setTimeout(r, 3000));
      try {
        const fresh = await fetch('https://book-stats.hello-5b9.workers.dev/book-sales').then(r => r.json());
        const freshSold = (fresh.total ?? 0) + GEYSER_SALES + WP_SALES;
        if (freshSold > knownSold) {
          bookSaleCounter.textContent = freshSold + ' / ' + PRINT_RUN + ' sold';
          showBookSale(freshSold);
          return;
        }
      } catch {}
    }
    showBookSale(null);
  }

  async function pollBookSales() {
    try {
      const data = await fetch('https://book-stats.hello-5b9.workers.dev/book-sales').then(r => r.json());
      const sold = (data.total ?? 0) + GEYSER_SALES + WP_SALES;
      bookSaleCounter.textContent = sold + ' / ' + PRINT_RUN + ' sold';
      if (lastBookOrderDate !== null && data.lastOrderDate !== lastBookOrderDate) {
        lastBookOrderDate = data.lastOrderDate;
        waitForUpdatedCount(sold);
      } else {
        lastBookOrderDate = data.lastOrderDate;
      }
    } catch {}
  }

  pollBookSales();

  setInterval(pollBookSales, 30000);

</script>

<script type="module">
  import { initNostr, subscribeStreamInfo, subscribeZaps, subscribeChat, subscribeRaids, subscribeNotifications, fetchProfile } from '/assets/js/radio/nostr.js';
  import * as nip19 from '/assets/js/vendor/nostr-nip19.js';

  // ----------------
  // CONFIG
  // ----------------
  const NADDR     = 'naddr1qqjr2vehvyenvdtr94nrzetr956rgctr94skvvfs95eryep3x3snwve389nxyqgwwaehxw309ahx7uewd3hkctczyr85tf46zd366lkjzws83ecs6fq3ttnjrjd500g7haz936h0knp22qcyqqq8vecjrlda8';
  const RELAYS    = ['wss://relay.primal.net', 'wss://nos.lol', 'wss://relay.damus.io'];
  const MY_PUBKEY = '55f04590674f3648f4cdc9dc8ce32da2a282074cd0b020596ee033d12d385185';

  const MAX_CHAT_DOM = 15;

  const chatBox = document.getElementById('chat-box');
  const seenMessages = new Set();
  const seenZaps = new Set();
  const seenRaids = new Set();
  const historicalZapsForChat = [];
  const historicalChatMsgs = [];
  const historicalRaids = [];
  let chatHistoricalDone = false;
  let historicalRendered = false;

  initNostr(NADDR, RELAYS, MY_PUBKEY);

  // Reload every hour to keep relay connections fresh on the 24/7 stream
  setTimeout(() => window.location.reload(), 60 * 60 * 1000);

  const viewersBar = document.getElementById('viewers-bar');
  subscribeStreamInfo(info => {
    if (info.viewers !== null && info.viewers > 0) {
      viewersBar.innerHTML = `<span>${info.viewers} listening</span>`;
      viewersBar.style.opacity = '1';
    } else {
      viewersBar.style.opacity = '0';
    }
  });

  // ----------------
  // CHAT HELPERS
  // ----------------
  function insertInOrder(el, timestamp) {
    el.dataset.ts = timestamp;
    const children = chatBox.children;
    let refNode = null;
    for (let i = 0; i < children.length; i++) {
      const ts = parseInt(children[i].dataset.ts, 10);
      if (!isNaN(ts) && ts > timestamp) { refNode = children[i]; break; }
    }
    if (refNode) chatBox.insertBefore(el, refNode);
    else chatBox.appendChild(el);
    while (chatBox.children.length > MAX_CHAT_DOM) chatBox.firstElementChild.remove();
    if (!refNode) chatBox.scrollTop = chatBox.scrollHeight;
  }

  function appendZapToChat(zap) {
    if (!chatBox) return;
    const el = document.createElement('div');
    el.className = 'ov-msg ov-msg--zap' +
      (zap.amount >= 5000 ? ' ov-msg--zap-big ov-msg--zap-mega' :
       zap.amount >= 1000 ? ' ov-msg--zap-big' :
       zap.amount < 100  ? '' : ' ov-msg--zap-small');

    const header = document.createElement('div');
    header.className = 'ov-msg-zap-header';

    const amount = document.createElement('span');
    amount.className = 'ov-msg-name ov-msg-zap-amount';
    amount.appendChild(document.createTextNode('⚡\u00A0'));
    zap.amount.toLocaleString().split('').forEach((char, i) => {
      const s = document.createElement('span');
      s.textContent = char;
      s.style.animationDelay = `${i * 0.06}s`;
      amount.appendChild(s);
    });
    header.appendChild(amount);

    if (zap.senderPubkey) {
      const sender = document.createElement('span');
      sender.className = 'ov-msg-name';
      sender.textContent = zap.senderPubkey.slice(0, 8);
      fetchProfile(zap.senderPubkey).then(p => { sender.textContent = p.name; });
      header.appendChild(sender);
    } else if (zap.name) {
      const sender = document.createElement('span');
      sender.className = 'ov-msg-name';
      sender.textContent = zap.name;
      header.appendChild(sender);
    }

    el.appendChild(header);

    if (zap.content) {
      const text = document.createElement('div');
      text.className = 'ov-msg-content';
      text.textContent = zap.content;
      el.appendChild(text);
    }

    insertInOrder(el, zap.timestamp);
  }

  function renderContentWithMentions(el, text, emojiMap = {}) {
    const tokenPattern = /(https?:\/\/[^\s]+)|(?:nostr:|@)(npub1[a-z0-9]+|nprofile1[a-z0-9]+)|:([a-zA-Z0-9_]+):/g;
    let lastIndex = 0;
    let match;
    while ((match = tokenPattern.exec(text)) !== null) {
      if (match.index > lastIndex) el.appendChild(document.createTextNode(text.slice(lastIndex, match.index)));
      if (match[1]) {
        const span = document.createElement('span');
        span.className = 'ov-msg-link';
        span.textContent = match[1].length > 30 ? match[1].slice(0, 30) + '…' : match[1];
        el.appendChild(span);
      } else if (match[2]) {
        try {
          const decoded = nip19.decode(match[2]);
          const pk = decoded.type === 'npub' ? decoded.data : decoded.data?.pubkey;
          const span = document.createElement('span');
          span.className = 'ov-msg-mention';
          if (pk) {
            fetchProfile(pk).then(p => {
              span.textContent = `@${p?.name || match[2].slice(0, 12) + '…'}`;
            });
          } else {
            span.textContent = `@${match[2].slice(0, 12)}…`;
          }
          el.appendChild(span);
        } catch {
          el.appendChild(document.createTextNode(match[0]));
        }
      } else if (match[3] && emojiMap[match[3]]) {
        const img = document.createElement('img');
        img.src = emojiMap[match[3]];
        img.alt = `:${match[3]}:`;
        img.className = 'ov-emoji';
        el.appendChild(img);
      } else {
        el.appendChild(document.createTextNode(match[0]));
      }
      lastIndex = match.index + match[0].length;
    }
    if (lastIndex < text.length) el.appendChild(document.createTextNode(text.slice(lastIndex)));
  }

  function appendChatMessage(msg) {
    if (!chatBox) return;

    const el = document.createElement('div');
    el.className = 'ov-msg';

    const img = document.createElement('img');
    img.className = 'ov-msg-avatar';
    img.style.display = 'none';
    img.onerror = function() { this.remove(); };
    el.appendChild(img);

    const body = document.createElement('div');
    body.className = 'ov-msg-body';

    const sender = document.createElement('span');
    sender.className = 'ov-msg-name';
    sender.textContent = msg.pubkey.slice(0, 8);

    const emojiMap = {};
    if (msg.tags) {
      for (const tag of msg.tags) {
        if (tag[0] === 'emoji' && tag[1] && tag[2]) emojiMap[tag[1]] = tag[2];
      }
    }

    const text = document.createElement('span');
    renderContentWithMentions(text, msg.content, emojiMap);

    body.appendChild(sender);
    body.appendChild(text);
    el.appendChild(body);

    fetchProfile(msg.pubkey).then(p => {
      const name = p.name || msg.pubkey.slice(0, 8);
      sender.textContent = name.length > 12 ? name.slice(0, 12) + '…' : name;
      if (p.picture) { img.src = p.picture; img.style.display = ''; }
      else { img.remove(); }
    });

    insertInOrder(el, msg.timestamp);
  }

  function appendRaidToChat(raid) {
    if (!chatBox) return;

    const el = document.createElement('div');
    el.className = 'ov-msg ov-msg--raid';

    const span = document.createElement('span');
    span.textContent = `RAID FROM ${raid.pubkey.slice(0, 8)}`;
    fetchProfile(raid.pubkey).then(p => { span.textContent = `RAID FROM ${p.name}`; });
    el.appendChild(span);

    insertInOrder(el, raid.timestamp);
  }

  // ----------------
  // HISTORICAL RENDER
  // ----------------
  function maybeRenderHistorical() {
    if (!chatHistoricalDone || historicalRendered) return;
    historicalRendered = true;

    const firstChatTs = historicalChatMsgs.length > 0
      ? Math.min(...historicalChatMsgs.map(m => m.timestamp))
      : 0;

    const items = [
      ...historicalChatMsgs.slice(-MAX_CHAT_DOM).map(m => ({ type: 'chat', timestamp: m.timestamp, data: m })),
      ...historicalZapsForChat
        .filter(z => z.timestamp >= firstChatTs)
        .slice(-MAX_CHAT_DOM)
        .map(z => ({ type: 'zap', timestamp: z.timestamp, data: z })),
      ...historicalRaids.slice(-5).map(r => ({ type: 'raid', timestamp: r.timestamp, data: r })),
    ].sort((a, b) => a.timestamp - b.timestamp);

    items.forEach(item => {
      if (item.type === 'chat') appendChatMessage(item.data);
      else if (item.type === 'zap') appendZapToChat(item.data);
      else appendRaidToChat(item.data);
    });

    historicalZapsForChat.length = 0;

    chatBox.scrollTop = chatBox.scrollHeight;
    if (window.__resolveChatReady) window.__resolveChatReady();
  }

  // ----------------
  // NOSTR SUBSCRIPTIONS
  // ----------------
  subscribeZaps(async (zap, isHistorical) => {
    if (seenZaps.has(zap.id)) return;
    seenZaps.add(zap.id);
    if (isHistorical) {
      if (zap.isStreamZap) historicalZapsForChat.push(zap);
    } else {
      if (zap.isStreamZap) appendZapToChat(zap);
      fetchProfile(zap.senderPubkey || '').then(p => addZap({ sats: zap.amount, name: p.name, avatar: p.picture, message: zap.content }));
    }
  }, () => {
    if (historicalRendered) {
      historicalZapsForChat.forEach(z => { if (z.isStreamZap) appendZapToChat(z); });
    } else {
      maybeRenderHistorical();
    }
  });

  subscribeChat((msg, isHistorical) => {
    if (seenMessages.has(msg.id)) return;
    seenMessages.add(msg.id);
    if (isHistorical) { historicalChatMsgs.push(msg); return; }
    appendChatMessage(msg);
  }, () => {
    chatHistoricalDone = true;
    maybeRenderHistorical();
  });

  subscribeRaids((raid, isHistorical) => {
    if (seenRaids.has(raid.timestamp + raid.pubkey)) return;
    seenRaids.add(raid.timestamp + raid.pubkey);
    if (isHistorical) { historicalRaids.push(raid); return; }
    appendRaidToChat(raid);
  }, () => {
    if (historicalRendered) {
      historicalRaids.forEach(r => appendRaidToChat(r));
    } else {
      maybeRenderHistorical();
    }
  });

  // ----------------
  // NOTIFICATION CENTER
  // ----------------
  const followFeed = document.getElementById('follow-feed');
  const MAX_NOTIFS = 3;
  const seenNotifs = new Set();
  const notifQueue = [];

  const NOTIF_LABELS = {
    post:     'posted a new note',
    zap:      'zapped NoGood',
    comment:  'commented on NoGood',
    reaction: 'liked NoGood\'s post',
    reply:    'replied to NoGood',
  };

  function addNotification(name, type, pubkey) {
    const label = NOTIF_LABELS[type] || type;

    // Snapshot positions of items that are staying
    const snapshots = [...followFeed.children]
      .map(el => ({ el, top: el.getBoundingClientRect().top }));

    // Add new item invisibly
    const item = document.createElement('div');
    item.className = 'follow-notif';
    item.textContent = `${name} ${label}`;
    followFeed.insertBefore(item, followFeed.firstChild);
    followFeed.getBoundingClientRect();

    // FLIP invert: push staying items back down
    snapshots.forEach(({ el, top }) => {
      const dy = top - el.getBoundingClientRect().top;
      if (Math.abs(dy) < 0.5) return;
      el.style.transition = 'none';
      el.style.transform = `translateY(${dy}px)`;
    });
    followFeed.getBoundingClientRect();

    // Phase 1: animate staying items up
    requestAnimationFrame(() => {
      snapshots.forEach(({ el }) => {
        el.style.transition = 'transform 0.35s ease';
        el.style.transform = '';
      });
    });

    // Phase 2: after move, fade in new item + resolve profile
    setTimeout(() => {
      snapshots.forEach(({ el }) => { el.style.transition = ''; });
      item.style.transition = 'opacity 0.35s ease';
      item.classList.add('is-in');
      if (pubkey) fetchProfile(pubkey).then(p => {
        const resolvedName = p.name.length > 10 ? p.name.slice(0, 10) + '…' : p.name;
        item.textContent = `${resolvedName} ${label}`;
      });
    }, 350);

    // Auto fade-out after 15s
    setTimeout(() => {
      if (!item.isConnected) return;
      item.style.transition = 'opacity 0.6s ease';
      item.classList.remove('is-in');
      item.classList.add('is-out');
      setTimeout(() => { item.remove(); drainQueue(); }, 600);
    }, 30000);

    return item;
  }

  function drainQueue() {
    if (notifQueue.length === 0 || followFeed.children.length >= MAX_NOTIFS) return;
    const next = notifQueue.shift();
    addNotification(next.name, next.type, next.pubkey);
  }

  function queueNotification(name, type, pubkey) {
    if (followFeed.children.length < MAX_NOTIFS) {
      addNotification(name, type, pubkey);
    } else {
      notifQueue.push({ name, type, pubkey });
    }
  }


  // Delay until after main mux EOSE (4s timeout + buffer)
  setTimeout(() => subscribeNotifications(({ type, pubkey, id, own }) => {
    if (seenNotifs.has(id)) return;
    seenNotifs.add(id);
    if (type === 'follow') return;
    queueNotification(pubkey.slice(0, 8), type, pubkey);
  }), 6000);


</script>
