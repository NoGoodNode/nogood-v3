  // ----------------
  const zlBar   = document.getElementById('zl-wrap');
  const zlTrack = document.getElementById('zl-track');
  const zlLabel = document.getElementById('zl-top');

  function decodeBolt11Amount(bolt11) {
    const match = bolt11.match(/^lnbc(\d+)([munp]?)/i);
    if (!match) return 0;
    const num = parseInt(match[1], 10);
    switch (match[2]) {
      case 'm': return num * 100000;
      case 'u': return num * 100;
      case 'n': return Math.floor(num / 10);
      case 'p': return Math.floor(num / 10000);
      default:  return num * 100000000;
    }
  }

  function fmtSats(n) {
    if (n >= 1000000) return (n / 1000000).toFixed(1) + 'M';
    if (n >= 1000) return Math.round(n / 1000) + 'K';
    return n.toString();
  }

  function setZapLeaderEntries(entries) {
    zlTrack.style.animation = 'none';
    zlTrack.innerHTML = '';
    const buildCopy = () => {
      entries.forEach(({ rank, name, amount }) => {
        const nameSpan = document.createElement('span');
        nameSpan.className = 'zl-name';
        nameSpan.textContent = `${rank}. ${name}`;
        const amtSpan = document.createElement('span');
        amtSpan.className = 'zl-amount';
        amtSpan.textContent = amount;
        const sep = document.createElement('span');
        sep.className = 'zl-sep';
        sep.textContent = '//';
        zlTrack.appendChild(nameSpan);
        zlTrack.appendChild(amtSpan);
        zlTrack.appendChild(sep);
      });
    };
    for (let i = 0; i < 6; i++) buildCopy();
    requestAnimationFrame(() => {
      const singleWidth = zlTrack.scrollWidth / 6;
      const duration = singleWidth / 12;
      zlTrack.style.setProperty('--zl-scroll-width', `-${singleWidth}px`);
      zlTrack.style.animation = `scrollZapLeader ${duration}s linear infinite`;
      zlBar.style.opacity = '1';
    });
  }

  async function buildZapLeaderboard() {
    const pool       = getPool();
    const streamATag = getStreamATag();
    const events     = await pool.querySync(RELAYS, { kinds: [9735], '#a': [streamATag], limit: 500 }, { maxWait: 3000 });

    const totals = new Map();
    events.forEach(e => {
      const descTag = e.tags.find(t => t[0] === 'description');
      if (!descTag) return;
      let req; try { req = JSON.parse(descTag[1]); } catch { return; }
      const bolt11 = e.tags.find(t => t[0] === 'bolt11');
      if (!bolt11 || !req.pubkey || req.pubkey === MY_PUBKEY) return;
      totals.set(req.pubkey, (totals.get(req.pubkey) || 0) + decodeBolt11Amount(bolt11[1]));
    });

    const top5 = [...totals.entries()].sort((a, b) => b[1] - a[1]).slice(0, 5);
    if (!top5.length) return;

    const profiles = await Promise.all(top5.map(([pk]) => fetchProfile(pk).catch(() => null)));

    const entries = top5.map(([pk, total], i) => {
      const p = profiles[i];
      const raw = p?.name || pk.slice(0, 8);
      const name = (raw.length > 20 ? raw.slice(0, 20) + '…' : raw).toUpperCase();
      return { rank: i + 1, name, amount: fmtSats(total) };
    });

    const top = entries[0];
    const mkBounce = (text, cls, ml, startI) => {
      const w = document.createElement('span');
      w.className = cls;
      if (ml) w.style.marginLeft = ml;
      [...text].forEach((ch, i) => {
        const s = document.createElement('span');
        s.textContent = ch;
        s.style.animationDelay = `${(startI + i) * 0.06}s`;
        w.appendChild(s);
      });
      return w;
    };
    zlLabel.innerHTML = '';
    const zlPrefix = document.createElement('span');
    zlPrefix.style.cssText = 'display:inline-block;transform:translateY(1px)';
    zlPrefix.textContent = 'TOP ZAP:';
    zlLabel.appendChild(zlPrefix);
    const nameEl = mkBounce(top.name, 'zl-name', '6px', 0);
    nameEl.style.transform = 'translateY(1px)';
    const amtEl = mkBounce(top.amount, 'zl-amount', '8px', top.name.length);
    amtEl.style.transform = 'translateY(1px)';
    zlLabel.appendChild(nameEl);
    zlLabel.appendChild(amtEl);

    setZapLeaderEntries(entries);
  }

  setTimeout(buildZapLeaderboard, 2000);

