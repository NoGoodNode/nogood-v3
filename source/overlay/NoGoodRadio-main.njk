<script>
  // ----------------
  // ZAP BAR
  // ----------------
  let resolveMempoolReady, resolveChatReady;
  const mempoolReady = new Promise(r => { resolveMempoolReady = r; });
  const chatReady    = new Promise(r => { resolveChatReady    = r; window.__resolveChatReady = r; });

  mempoolReady.then(() => { document.getElementById('mempool-bar').style.opacity = '1'; });
  chatReady.then(()    => { document.getElementById('chat-box').style.opacity    = '1'; });

  const zlScroll     = document.getElementById('zl-scroll');
  const zapIncoming  = document.getElementById('zap-incoming');
  const zapQueue     = [];
  let zapShowing     = false;

  function showNextZap() {
    if (zapQueue.length === 0) { zapShowing = false; return; }
    zapShowing = true;
    const zap = zapQueue.shift();

    const fmtAmt = n => n >= 1000000 ? (n/1000000).toFixed(1)+'M' : n >= 1000 ? Math.round(n/1000)+'K' : String(n);
    const name   = (zap.name || 'ANON').toUpperCase().slice(0, 20);
    const amount = fmtAmt(zap.sats);

    const track = document.createElement('div');
    track.style.cssText = 'display:flex;white-space:nowrap;will-change:transform;align-items:center;gap:20px;';

    const mkSpan = (cls, text) => { const s = document.createElement('span'); s.className = cls; s.textContent = text; return s; };
    const mkAmount = () => {
      const wrap = document.createElement('span');
      wrap.className = 'zl-amount';
      wrap.style.cssText = 'display:inline-flex;align-items:center;gap:8px;';
      ['⚡', amount, '⚡'].forEach((t, i) => {
        if (i !== 1) {
          const s = document.createElement('span');
          s.style.cssText = "font-family:'Offbit-Bold',monospace;transform:translateY(3px);display:inline-block;";
          s.textContent = t;
          wrap.appendChild(s);
        } else {
          const amtInner = document.createElement('span');
          [...t].forEach((ch, j) => {
            const s = document.createElement('span');
            s.style.cssText = 'display:inline-block;animation:letterBounce 2.5s ease infinite;';
            s.style.animationDelay = `${j * 0.06}s`;
            s.textContent = ch;
            amtInner.appendChild(s);
          });
          wrap.appendChild(amtInner);
        }
      });
      return wrap;
    };
    const buildCopy = () => {
      track.appendChild(mkSpan('zl-name', 'INCOMING ZAP'));
      track.appendChild(mkAmount());
      track.appendChild(mkSpan('zl-name', name));
      if (zap.message) track.appendChild(mkSpan('zl-message', zap.message.toUpperCase().slice(0, 80)));
      track.appendChild(mkSpan('zl-sep', '//'));
    };
    for (let i = 0; i < 6; i++) buildCopy();

    zapIncoming.innerHTML = '';
    zapIncoming.appendChild(track);

    const leaderBar = document.getElementById('zap-leader-bar');
    zlScroll.style.transition = 'opacity 0.4s ease';
    zlScroll.style.opacity = '0';
    setTimeout(() => {
      leaderBar.style.background = 'rgb(248, 194, 40)';
      setTimeout(() => {
        requestAnimationFrame(() => {
          const singleWidth = track.scrollWidth / 6;
          track.style.setProperty('--zl-scroll-width', `-${singleWidth}px`);
          track.style.animation = `scrollZapLeader ${singleWidth / 12}s linear infinite`;
          zapIncoming.style.opacity = '1';
          setTimeout(() => {
            zapIncoming.style.opacity = '0';
            setTimeout(() => {
              zapIncoming.innerHTML = '';
              leaderBar.style.background = 'rgba(28, 28, 28, 0.9)';
              setTimeout(() => {
                zlScroll.style.opacity = '1';
                setTimeout(showNextZap, 10000);
              }, 900);
            }, 400);
          }, 30000);
        });
      }, 900);
    }, 400);
  }

  function addZap(zap) {
    zapQueue.push(zap);
    if (!zapShowing) showNextZap();
  }

  // ----------------
  // MEMPOOL BAR
  // ----------------
  const mempoolBar = document.getElementById('mempool-bar');
  const MEMPOOL_FIELDS = [
    { label: 'BLOCK',      key: 'block' },
    { label: 'MEMPOOL',    key: 'count' },
    { label: 'FEE',        key: 'halfHourFee', suffix: ' sat/vB' },
    { label: 'DIFFICULTY', key: 'difficultyChange', suffix: '%' },
  ];

  function renderMempoolData(data) {
    mempoolBar.innerHTML = '';
    MEMPOOL_FIELDS.forEach(({ label, key, suffix = '' }) => {
      const val = data[key];
      if (val == null) return;
      const row = document.createElement('div');
      row.className = 'mempool-row';
      const l = document.createElement('span');
      l.className = 'mempool-cell mempool-label';
      l.textContent = label;
      const v = document.createElement('span');
      v.className = 'mempool-cell mempool-value';
      v.textContent = (typeof val === 'number' ? val.toLocaleString() : val) + suffix;
      row.appendChild(l);
      row.appendChild(v);
      mempoolBar.appendChild(row);
    });
    resolveMempoolReady();
  }

  async function fetchMempool() {
    try {
      const [block, mempool, fees, difficulty] = await Promise.all([
        fetch('https://mempool.space/api/blocks/tip/height').then(r => r.text()),
        fetch('https://mempool.space/api/mempool').then(r => r.json()),
        fetch('https://mempool.space/api/v1/fees/recommended').then(r => r.json()),
        fetch('https://mempool.space/api/v1/difficulty-adjustment').then(r => r.json()),
      ]);
      renderMempool({
        block: parseInt(block),
        count: mempool.count,
        halfHourFee: fees.halfHourFee,
        difficultyChange: (difficulty.difficultyChange > 0 ? '+' : '') + difficulty.difficultyChange.toFixed(2),
      });
    } catch { resolveMempoolReady(); }
  }

  // ----------------
  // BLOCK BAR
  // ----------------
  let lastBlockHeight = null;
  let blockBarTimeout = null;
  const blockBar  = document.getElementById('block-bar');
  const blockText = document.getElementById('block-text');
  const BLOCK_TEXTS = ['NEW BLOCK', null]; // null = block number

  function showBlockBar(height) {
    if (blockBarTimeout) clearTimeout(blockBarTimeout);

    // Lock width to widest text variant (position:absolute — no layout side effects)
    blockBar.style.visibility = 'hidden';
    blockBar.style.display = 'flex';
    blockBar.style.width = 'auto';
    const allTexts = BLOCK_TEXTS.map(t => t === null ? height.toLocaleString() : t);
    let maxWidth = 0;
    allTexts.forEach(t => {
      blockText.textContent = t;
      maxWidth = Math.max(maxWidth, blockBar.getBoundingClientRect().width);
    });
    blockBar.style.width = maxWidth + 'px';
    blockBar.style.visibility = '';
    requestAnimationFrame(() => blockBar.classList.add('is-visible'));

    let phase = 0;
    function cycleText() {
      const label = BLOCK_TEXTS[phase % BLOCK_TEXTS.length];
      blockText.textContent = label === null ? height.toLocaleString() : label;
      phase++;
    }
    cycleText();
    const cycleInterval = setInterval(cycleText, 8000);

    blockBarTimeout = setTimeout(() => {
      clearInterval(cycleInterval);
      blockBar.classList.remove('is-visible');
      setTimeout(() => { blockBar.style.display = 'none'; }, 400);
    }, 30000);
  }

  function renderMempool(data) {
    renderMempoolData(data);
    if (lastBlockHeight !== null && data.block > lastBlockHeight) {
      showBlockBar(data.block);
    }
    lastBlockHeight = data.block;
  }

  fetchMempool();
  setInterval(fetchMempool, 60000);


  // ----------------
  // NOW PLAYING
  // ----------------
  const npBar   = document.getElementById('now-playing-bar');
  const npTrack = document.getElementById('np-track');
  let npCurrentText = '';

  function setNowPlayingText(text) {
    if (text === npCurrentText) return;
    npCurrentText = text;

    const populate = () => {
      npTrack.style.animation = 'none';
      npTrack.innerHTML = '';
      Array(10).fill(text).forEach(t => {
        const span = document.createElement('span');
        span.className = 'np-item';
        span.textContent = t;
        npTrack.appendChild(span);
        const sep = document.createElement('span');
        sep.className = 'np-sep';
        sep.textContent = '//';
        npTrack.appendChild(sep);
      });
      requestAnimationFrame(() => {
        const singleWidth = npTrack.scrollWidth / 10;
        const duration = singleWidth / 12;
        npTrack.style.setProperty('--np-scroll-width', `-${singleWidth}px`);
        npTrack.style.animation = `scrollNowPlaying ${duration}s linear infinite`;
        npTrack.style.opacity = '1';
        npBar.style.opacity = '1';
      });
    };

    if (npBar.style.opacity === '1') {
      npTrack.style.transition = 'opacity 0.6s ease';
      npTrack.style.opacity = '0';
      setTimeout(populate, 600);
    } else {
      npTrack.style.opacity = '1';
      populate();
    }
  }

  async function fetchNowPlaying() {
    try {
      const resp = await fetch('https://lastfm-api.hello-5b9.workers.dev/', { cache: 'no-store' });
      if (!resp.ok) { setNowPlayingText('NOGOOD RADIO'); return; }
      const tracks = await resp.json();
      const current = tracks.find(t => !t.playedAt);
      if (!current) { setNowPlayingText('NOGOOD RADIO'); return; }

      setNowPlayingText(`${current.artist} — ${current.name}`);
    } catch { setNowPlayingText('NOGOOD RADIO'); }
  }

  fetchNowPlaying();
  setInterval(fetchNowPlaying, 20000);

  // ----------------
  // BADGE
  // ----------------
  const badge = document.getElementById('overlay-badge');
  const BADGE_WAIT = 8 * 60 * 1000;
  const BADGE_SHOW = 20 * 1000;

  function badgeCycle() {
    badge.style.opacity = '1';
    badge.style.transform = 'translateY(0)';
    setTimeout(() => {
      badge.style.opacity = '0';
      badge.style.transform = 'translateY(20px)';
      setTimeout(badgeCycle, BADGE_WAIT);
    }, BADGE_SHOW);
  }

  setTimeout(badgeCycle, BADGE_WAIT);

  // ----------------
  // NODE STATUS
  // ----------------
  const nodeBar = document.getElementById('node-bar');
  let nodeOfflineCount = 0;
  let nodeInitialized = false;
  let nodeStatus = null;
  const NODE_OFFLINE_THRESHOLD = 3; // 3 × 120s = 6 minutes

  function setNodeOnline() {
    nodeOfflineCount = 0;
    const prev = nodeStatus;
    nodeStatus = 'online';
    nodeBar.className = 'status-pill node-online';
    nodeBar.innerHTML = '<span>NOGOODNODE ONLINE</span><span class="node-dot"></span>';
    if (!nodeInitialized) { nodeInitialized = true; nodeBar.style.opacity = '1'; }
    else if (prev !== 'online') window.__addOverlayNotification?.('NOGOODNODE', 'node_online');
  }

  function setNodeOffline(force = false) {
    nodeOfflineCount++;
    if (force || nodeOfflineCount >= NODE_OFFLINE_THRESHOLD) {
      const prev = nodeStatus;
      nodeStatus = 'offline';
      nodeBar.className = 'status-pill node-offline';
      nodeBar.innerHTML = '<span>NOGOODNODE OFFLINE</span><span class="node-dot"></span>';
      if (!nodeInitialized) { nodeInitialized = true; nodeBar.style.opacity = '1'; }
      else if (prev !== 'offline') window.__addOverlayNotification?.('NOGOODNODE', 'node_offline');
    }
  }

  async function checkNode() {
    try {
      const res = await fetch('https://btcpay.hello-5b9.workers.dev/health', {
        cache: 'no-store',
        signal: AbortSignal.timeout(5000)
      });
      const data = await res.json();
      res.ok && data.synchronized === true ? setNodeOnline() : setNodeOffline(!nodeInitialized);
    } catch {
      setNodeOffline(!nodeInitialized);
    }
  }

  checkNode();
  setInterval(checkNode, 120000);

  // ----------------
  // RELAY STATUS
  // ----------------
  const relayBar = document.getElementById('relay-bar');
  const RELAY_URL = 'wss://relay.nogood.tech/';
  let relayOfflineCount = 0;
  let relayInitialized = false;
  let relayStatus = null;
  const RELAY_OFFLINE_THRESHOLD = 3; // 3 × 600s = 30 minutes

  function setRelayOnline() {
    relayOfflineCount = 0;
    const prev = relayStatus;
    relayStatus = 'online';
    relayBar.className = 'status-pill node-online';
    relayBar.innerHTML = '<span>NoGoodRelay Online</span><span class="node-dot"></span>';
    if (!relayInitialized) { relayInitialized = true; relayBar.style.opacity = '1'; }
    else if (prev !== 'online') window.__addOverlayNotification?.('NOGOODRELAY', 'relay_online');
  }

  function setRelayOffline(force = false) {
    relayOfflineCount++;
    if (force || relayOfflineCount >= RELAY_OFFLINE_THRESHOLD) {
      const prev = relayStatus;
      relayStatus = 'offline';
      relayBar.className = 'status-pill node-offline';
      relayBar.innerHTML = '<span>NoGoodRelay Offline</span><span class="node-dot"></span>';
      if (!relayInitialized) { relayInitialized = true; relayBar.style.opacity = '1'; }
      else if (prev !== 'offline') window.__addOverlayNotification?.('NOGOODRELAY', 'relay_offline');
    }
  }

  function checkRelay() {
    let settled = false;
    let ws;
    const timeout = setTimeout(() => {
      if (settled) return;
      settled = true;
      if (ws) ws.close();
      setRelayOffline(!relayInitialized);
    }, 5000);

    try {
      ws = new WebSocket(RELAY_URL);
    } catch {
      clearTimeout(timeout);
      setRelayOffline(!relayInitialized);
      return;
    }

    ws.onopen = () => {
      if (settled) return;
      settled = true;
      clearTimeout(timeout);
      setRelayOnline();
      ws.close();
    };

    ws.onerror = () => {
      if (settled) return;
      settled = true;
      clearTimeout(timeout);
      setRelayOffline(!relayInitialized);
    };
  }

  checkRelay();
  setInterval(checkRelay, 600000);

  // ----------------
  // BOOK SALES
  // ----------------
  const GEYSER_SALES  = {{ booksales.geyser_sales }};
  const WP_SALES      = {{ booksales.wordpress_sales }};
  const PRINT_RUN     = 400; // overlay-only total, intentionally decoupled from booksales.yaml
  const bookBar         = document.getElementById('book-sale-bar');
  const bookSaleCounter = document.getElementById('book-sale-counter');
  let lastBookOrderDate = null;
  let bookBarActive = false;
  const bookBarQueue = [];

  function displayBookBar(sold) {
    bookBarActive = true;
    const bookPicture = bookBar.querySelector('img');
    const bookLabel   = document.getElementById('book-sale-label');
    if (sold !== null) {
      bookSaleCounter.textContent = sold + ' / ' + PRINT_RUN + ' sold';
      bookSaleCounter.style.display = '';
    } else {
      bookSaleCounter.style.display = 'none';
    }
    [bookPicture, bookLabel, bookSaleCounter].forEach((el, i) => {
      el.classList.remove('book-item-in');
      void el.offsetWidth;
      el.style.animationDelay = (i * 0.15) + 's';
      el.classList.add('book-item-in');
    });
    bookBar.style.opacity = '1';
    setTimeout(() => {
      [bookSaleCounter, bookLabel, bookPicture].forEach((el, i) => {
        el.classList.remove('book-item-in');
        void el.offsetWidth;
        el.style.animationDelay = (i * 0.15) + 's';
        el.classList.add('book-item-out');
      });
      setTimeout(() => {
        bookBar.style.opacity = '0';
        [bookPicture, bookLabel, bookSaleCounter].forEach(el => {
          el.classList.remove('book-item-out');
          el.style.animationDelay = '';
          el.style.display = '';
        });
        bookBarActive = false;
        if (bookBarQueue.length > 0) {
          displayBookBar(bookBarQueue.shift());
        }
      }, 3 * 150 + 600);
    }, 60000);
  }

  function showBookSale(sold) {
    if (bookBarActive) { bookBarQueue.push(sold); } else { displayBookBar(sold); }
  }

  async function fetchTotalSold() {
    const [bookData, printData] = await Promise.all([
      fetch('https://book-stats.hello-5b9.workers.dev/book-sales').then(r => r.json()),
      fetch('https://book-stats.hello-5b9.workers.dev/print-sales').then(r => r.json()),
    ]);
    const sold = (bookData.total ?? 0) + (printData.total ?? 0) + GEYSER_SALES + WP_SALES;
    return { sold, lastOrderDate: bookData.lastOrderDate };
  }

  async function waitForUpdatedCount(knownSold) {
    for (let i = 0; i < 4; i++) {
      await new Promise(r => setTimeout(r, 3000));
      try {
        const { sold: freshSold } = await fetchTotalSold();
        if (freshSold > knownSold) {
          bookSaleCounter.textContent = freshSold + ' / ' + PRINT_RUN + ' sold';
          showBookSale(freshSold);
          return;
        }
      } catch {}
    }
    showBookSale(null);
  }

  async function pollBookSales() {
    try {
      const { sold, lastOrderDate } = await fetchTotalSold();
      bookSaleCounter.textContent = sold + ' / ' + PRINT_RUN + ' sold';
      if (lastBookOrderDate !== null && lastOrderDate !== lastBookOrderDate) {
        lastBookOrderDate = lastOrderDate;
        window.__addOverlayNotification?.('', 'sale');
        waitForUpdatedCount(sold);
      } else {
        lastBookOrderDate = lastOrderDate;
      }
    } catch {}
  }

  pollBookSales();

  setInterval(pollBookSales, 300000);

  // ----------------
  // BOOK PROMO
  // ----------------
  const bookPromoBar  = document.getElementById('book-promo-bar');
  const bookPromoText = document.getElementById('book-promo-text');
  const BOOK_PROMO_TEXTS    = ['The NoGood Book', 'OUT NOW!', 'nogood.studio'];
  const BOOK_PROMO_TEXT_MS  = 5000;
  const BOOK_PROMO_SHOW_MS  = 60000;
  const BOOK_PROMO_EVERY_MS = 10 * 60 * 1000;
  let bookPromoTextTimer = null;

  function setBookPromoText(text) {
    bookPromoText.textContent = text;
    bookPromoText.classList.remove('book-item-in');
    void bookPromoText.offsetWidth;
    bookPromoText.classList.add('book-item-in');
  }

  function showBookPromo() {
    bookPromoBar.querySelector('video')?.play();
    let textIndex = 0;
    setBookPromoText(BOOK_PROMO_TEXTS[textIndex]);
    bookPromoBar.style.opacity = '1';

    bookPromoTextTimer = setInterval(() => {
      textIndex = (textIndex + 1) % BOOK_PROMO_TEXTS.length;
      setBookPromoText(BOOK_PROMO_TEXTS[textIndex]);
    }, BOOK_PROMO_TEXT_MS);

    setTimeout(() => {
      clearInterval(bookPromoTextTimer);
      bookPromoText.classList.remove('book-item-in');
      void bookPromoText.offsetWidth;
      bookPromoText.classList.add('book-item-out');
      setTimeout(() => {
        bookPromoBar.style.opacity = '0';
        bookPromoText.classList.remove('book-item-out');
      }, 600);
    }, BOOK_PROMO_SHOW_MS);
  }

  setInterval(showBookPromo, BOOK_PROMO_EVERY_MS);

</script>

<script type="module">
