---
layout: base.njk
title: Archive
description: "All NoGood blog posts, products, and clippings."
permalink: /archive/
---

<button id="scroll-to-top" class="scroll-to-top-button" aria-label="Scroll to top">
    <svg viewBox="0 0 9 5" xmlns="http://www.w3.org/2000/svg">
        <rect x="3" y="2" width="1" height="1"/>
        <rect x="2" y="2" width="1" height="1"/>
        <rect x="1" y="2" width="1" height="1"/>
        <rect y="2" width="1" height="1"/>
        <rect x="4" y="2" width="1" height="1"/>
        <rect x="5" y="2" width="1" height="1"/>
        <rect x="6" y="2" width="1" height="1"/>
        <rect x="7" y="2" width="1" height="1"/>
        <rect x="7" y="1" width="1" height="1"/>
        <rect x="7" y="3" width="1" height="1"/>
        <rect x="6" y="4" width="1" height="1"/>
        <rect x="6" width="1" height="1"/>
        <rect x="8" y="2" width="1" height="1"/>
    </svg>
</button>

<div id="archive" class="section medium-grid">
    {# HEADING #}
    <div class="section-column sticky-two-rows">
        <div class="sticky-wrapper">
            <div class="sticky">
                <h1 class="pixel-font uppercase">The Archive</h1>
            </div>
        </div>
    </div>

    {# LISTS #}
    <div class="section-column">
        <div class="inner-column">
            <h4 class="uppercase pixel-font">Blog Posts</h4>
            <div class="spacer"></div>
            <div class="list tag-list">
                {% for post in collections.feedPosts %}
                    {% include "source/snippets/list-tag.njk" %}
                {% endfor %}
            </div>

            <div class="spacer-extralarge"></div>

            <h4 class="uppercase pixel-font">Products</h4>
            <div class="spacer"></div>
            <div class="list two-col-list">
                {% for post in collections.product | reverse %}
                    <div>
                        <a href="{{ post.url }}">{{ post.data.title }}</a>
                    </div>
                    <div class="align-right text-tabular">
                        {% if post.data.site.sold_out %}
                        Sold Out
                        {% else %}
                        €{{ post.data.snipcart.price }}
                        {% endif %}
                    </div>
                    <div class="row-border"></div>
                {% endfor %}
            </div>

            <div class="spacer-extralarge"></div>

            <h4 class="uppercase pixel-font">Torrents</h4>
            <div class="spacer"></div>
            <div class="list two-col-list">
                {% for item in downloads.files %}
                    <div>{{ item.title }}</div>
                    <div class="align-right">
                        <a href="{{ item.dtan_url }}" class="icon external-icon">details</a>|
                        <a href="{{ item.torrent_url }}" class="icon download-icon">download</a>
                    </div>
                    <div class="row-border"></div>
                {% endfor %}
            </div>
        </div>
    </div>

    {# CLIPPINGS #}
    <div class="section-column">
        <h4 class="uppercase pixel-font">Clippings</h4>
        <div class="spacer"></div>
        <div class="list clippings-list">
            {% for item in collections.clippingsAll %}
                {% include "source/snippets/list-clippings.njk" %}
            {% endfor %}
        </div>
    </div>
</div>

<script>
(function () {
    var btn = document.getElementById('scroll-to-top');
    var trigger = document.querySelector('#archive .sticky-wrapper');
    if (!btn || !trigger) return;

    var archive = document.getElementById('archive');
    function checkVisibility() {
        var rect = trigger.getBoundingClientRect();
        btn.classList.toggle('is-visible', rect.top <= 0);
        if (archive) {
            var archiveBottom = archive.getBoundingClientRect().bottom;
            if (archiveBottom < window.innerHeight - 16) {
                btn.style.bottom = (window.innerHeight - archiveBottom + 16) + 'px';
            } else {
                btn.style.bottom = '';
            }
        }
    }

    window.addEventListener('scroll', checkVisibility, { passive: true });
    checkVisibility();

    var DURATION = 1500;
    function easeInOutQuad(t) {
        return t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2;
    }

    btn.addEventListener('click', function () {
        var startY = window.scrollY;
        var startTime = null;

        function step(timestamp) {
            if (startTime === null) startTime = timestamp;
            var progress = Math.min((timestamp - startTime) / DURATION, 1);
            window.scrollTo(0, startY * (1 - easeInOutQuad(progress)));
            if (progress < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
    });
})();
</script>
