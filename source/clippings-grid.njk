---
layout: base.njk
title: Clippings Grid
permalink: /clippings-grid/
unlisted: true
---

<div class="section padding-small">
    <div id="clipping-filters" class="tag-row"></div>
</div>
<div class="masonry masonry--borderless">
    {% for item in collections.clippingsAll %}
    <div class="masonry-item" data-category="{{ item.category }}">
        {% include "source/snippets/list-clippings.njk" %}
    </div>
    {% endfor %}
</div>

<script>
(function () {
    const items = document.querySelectorAll('.masonry-item[data-category]');
    const container = document.getElementById('clipping-filters');
    const cats = [...new Set([...items].map(el => el.dataset.category).filter(Boolean))].sort();
    let active = null;

    cats.forEach(cat => {
        const btn = document.createElement('button');
        btn.className = 'tag tag-dark pixel-font uppercase';
        btn.textContent = cat;
        btn.addEventListener('click', () => {
            if (active === cat) {
                active = null;
                items.forEach(el => el.classList.remove('is-muted', 'is-active'));
                container.querySelectorAll('button').forEach(b => b.classList.remove('tag--active'));
            } else {
                active = cat;
                items.forEach(el => {
                    const match = el.dataset.category === cat;
                    el.classList.toggle('is-muted', !match);
                    el.classList.toggle('is-active', match);
                });
                container.querySelectorAll('button').forEach(b => b.classList.toggle('tag--active', b.textContent === cat));
            }
        });
        container.appendChild(btn);
    });
})();
</script>
