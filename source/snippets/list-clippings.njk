<div class="outline padding-small{% if loop.first %} bg-offwhite{% endif %}">
    <a href="{{ item.url }}" target="_blank" rel="noopener" data-umami-event="clipping-click" data-umami-event-title="{{ item.title }}">{% if item.category == "podcast" %}<span class="play-circle"></span>{% endif %}{{ item.title }}</a>
    <div class="spacer"></div>
    {% if item.intro %}
    <p class="">{{ item.intro }}</p>
    {% endif %}
    {% if item.quote %}
    <div class="spacer-small"></div>
    <blockquote class="clipping-quote">{{ item.quote }}</blockquote>
    {% endif %}
    {% if item.embed %}
    <div class="spacer-small"></div>
    <div class="embed-facade" data-src="{{ item.embed }}"{% if item.embed_thumb %} style="background-image: url('{{ item.embed_thumb }}')"{% endif %}>
        <button class="embed-play" aria-label="Load embed"></button>
    </div>
    {% endif %}
    <div class="spacer"></div>
    <div class="flex-space-between">
        <div class="tag-row">
            <span class="tag tag-dark pixel-font uppercase">{{ item.category }}</span>
            <span class="text-small text-tabular">{{ item.date | postDate }}</span>
        </div>
        <a href="{{ item.url }}" target="_blank" rel="noopener" class="text-small" data-umami-event="clipping-click" data-umami-event-title="{{ item.title }}">Source</a>
    </div>
</div>
