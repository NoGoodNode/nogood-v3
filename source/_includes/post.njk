---
layout: base
---

<article>
    <div id="post" class="section medium-grid">
        <div class="section-column sticky-two-rows">
            <div class="sticky-wrapper">
                <div class="sticky">
                    <p class="text-small pixel-font uppercase">{% if number %}Book update {{ number }} — {% endif %}{{ date | postDate }}</p>
                    <h1 class="uppercase pixel-font header-extra-large">{{ title }}</h1>
                    <div class="spacer"></div>
                    {% if intro %}<p class="text-extra-large">{{ intro | safe }}</p>{% endif %}
                    <div class="spacer"></div>
                </div>
            </div>
            <div class="place-bottom hide-small">
                <div class="all-posts">
                    <h4 class="pixel-font uppercase">{% if cat === "book" %}All book updates{% else %}All in: {{ cat }}{% endif %}</h4>
                    <div class="spacer"></div>
                    <div class="list tag-list">
                        {% for post in collections.post | reverse %}
                            {% for tag in post.data.tags %}
                                {% if tag === cat %}
                                    {% include "source/snippets/list-tag.njk" %}
                                {% endif %}
                            {% endfor %}
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>

        <div class="section-column">
            {{ content | safe }}
            <div class="hide-medium hide-large">
                <div class="spacer-large"></div>
                <div class="all-posts">
                    <h4 class="pixel-font uppercase">{% if cat === "book" %}All book updates{% else %}All in: {{ cat }}{% endif %}</h4>
                    <div class="spacer"></div>
                    <div class="list tag-list">
                        {% for post in collections.post | reverse %}
                            {% for tag in post.data.tags %}
                                {% if tag === cat %}
                                    {% include "source/snippets/list-tag.njk" %}
                                {% endif %}
                            {% endfor %}
                        {% endfor %}
                    </div>
                </div>
                {% if cat === "book" %}
                <div class="spacer-large"></div>
                <a href="/the-nogood-book/" class="no-blend zoom display-block">
                    {% image "source/assets/img/book/NG_Shoot_Book_Cover_Featured.jpg", "The NoGood Book" %}
                </a>
                <div class="spacer-small"></div>
                <a href="/the-nogood-book/" class="pixel-font uppercase">The NoGood Book</a>
                <div class="spacer-small"></div>
                <p>
                    Self-published. Crowdfunded. A monograph bringing together five years of illustration projects, outlining the backdrop for and context within which my work was created.
                </p>
                <div class="spacer-small"></div>
                <div class="button-wrapper">
                    <a href="/the-nogood-book/" class="button pixel-font uppercase">
                        Buy now
                    </a>
                </div>
                <p class="text-small"><span id="book-sales-total-post-mobile"></span> in stock — limited run of 400</p>
                {% endif %}
            </div>
        </div>

        <div class="section-column hide-small">
            {% if cat === "book" %}
            <div class="sticky">
                <a href="/the-nogood-book/" class="no-blend zoom display-block">
                    {% image "source/assets/img/book/NG_Shoot_Book_Cover_Featured.jpg", "The NoGood Book" %}
                </a>
                <div class="spacer-small"></div>
                <a href="/the-nogood-book/" class="pixel-font uppercase">The NoGood Book</a>
                <div class="spacer-small"></div>
                <p>
                    Self-published. Crowdfunded. A monograph bringing together five years of illustration projects, outlining the backdrop for and context within which my work was created.
                </p>
                <div class="spacer-small"></div>
                <div class="button-wrapper">
                    <a href="/the-nogood-book/" class="button pixel-font uppercase">
                        Buy now
                    </a>
                </div>
                <p class="text-small">Limited run of 400 / <span id="book-sales-total-post"></span> in stock</p>
            </div>
            {% endif %}
        </div>
    </div>
</article>

{% if cat === "book" %}
<script>
    const bookRun = {{ booksales.book_run }};
    const printRun = {{ booksales.print_run }};
    const presales = {{ booksales.presales }};
    function setStock(val) {
        ['book-sales-total-post', 'book-sales-total-post-mobile'].forEach(id => {
            const el = document.getElementById(id);
            if (el) el.textContent = val;
        });
    }
    Promise.all([
        fetch('https://book-stats.hello-5b9.workers.dev/book-sales').then(r => r.json()),
        fetch('https://book-stats.hello-5b9.workers.dev/print-sales').then(r => r.json()),
    ]).then(([book, print]) => {
        const available = (bookRun - (book.total ?? 0)) + (printRun - ((print.total ?? 0) + presales));
        setStock(available);
    }).catch(() => {
        setStock(bookRun + (printRun - presales));
    });
</script>
{% endif %}
