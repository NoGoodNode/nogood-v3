    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-plugin-rss": "^2.0.4",
    "clean-css": "^5.3.3",
    "gray-matter": "^4.0.3",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "hls.js": "^1.6.16",
    "nostr-tools": "^2.23.3",
    "qrcode": "^1.5.4",
    "terser": "^5.46.1"
  }
